{
  "schemaVersion": 1,
  "id": "seeu",
  "version": "${version}",
  "name": "SeeU",
  "icon": "assets/seeu/icon.png",
  "description": "Makes distant players visible far beyond vanilla entity tracking.",
  "authors": [
    "Keryesh4ka"
  ],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.keryeshka.voxyseeu.fabric.VoxySeeUFabric"
    ],
    "client": [
      "dev.keryeshka.voxyseeu.fabric.client.VoxySeeUClient"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "fabric-api": "*"
  },
  "contact": {
    "sources": "https://github.com/cat4blep/SeeU",
    "issues": "https://github.com/cat4blep/SeeU/issues"
  },
  "suggests": {
    "modmenu": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.issues": "https://github.com/cat4blep/SeeU/issues"
      }
